# Copy to .env.local and fill in. Do NOT commit .env.local.
# These are read only by the server-side /api/contact route (Deployment Path A).

# Where contact-form submissions are delivered. Options depend on how you wire
# app/api/contact/route.ts — e.g. an email API key, or an inbound webhook URL.
# TODO(contact-email): the real BIQADX contact inbox is not yet supplied.
CONTACT_DELIVERY_WEBHOOK=
CONTACT_TO_EMAIL=

# If you later switch to Path B (static export), the form posts directly to a
# third-party service instead and these are unused:
# NEXT_PUBLIC_FORMSPREE_ENDPOINT=
